import React, { useState } from 'react';
import { motion, AnimatePresence } from 'motion/react';
import { ChevronLeft, ChevronRight, X, MessageSquare } from 'lucide-react';
import { useAuth } from '../context/AuthContext';
import ReviewPopup from './ReviewPopup';

interface MagazineReaderProps {
  magazine: any;
  onClose: () => void;
}

const MagazineReader: React.FC<MagazineReaderProps> = ({ magazine, onClose }) => {
  const [currentPage, setCurrentPage] = useState(0); // 0 is cover
  const [showReviews, setShowReviews] = useState(false);
  const { pages = [] } = magazine;

  // Logic for double pages:
  // Page 0: [Cover]
  // Page 1: [Page 1, Page 2]
  // Page 2: [Page 3, Page 4]
  // ...
  
  const totalSteps = Math.ceil((pages.length - 1) / 2) + 1;

  const next = () => {
    if (currentPage < totalSteps - 1) setCurrentPage(currentPage + 1);
  };

  const prev = () => {
    if (currentPage > 0) setCurrentPage(currentPage - 1);
  };

  const renderContent = () => {
    if (currentPage === 0) {
      return (
        <motion.div 
          key="cover"
          initial={{ rotateY: -90, opacity: 0 }}
          animate={{ rotateY: 0, opacity: 1 }}
          exit={{ rotateY: 90, opacity: 0 }}
          className="h-[80vh] aspect-[3/4] bg-white shadow-2xl relative preserve-3d"
        >
          <img src={pages[0]} alt="Cover" className="w-full h-full object-cover" />
        </motion.div>
      );
    }

    const startIndex = (currentPage - 1) * 2 + 1;
    const pageL = pages[startIndex];
    const pageR = pages[startIndex + 1];

    return (
      <motion.div 
        key={`pages-${currentPage}`}
        initial={{ opacity: 0, x: 20 }}
        animate={{ opacity: 1, x: 0 }}
        exit={{ opacity: 0, x: -20 }}
        className="flex h-[80vh] w-[140vh] bg-white shadow-2xl overflow-hidden rounded-sm"
      >
        <div className="flex-1 border-r border-wine/10 relative">
          <img src={pageL} alt={`Page ${startIndex + 1}`} className="w-full h-full object-cover" />
          <div className="absolute bottom-4 left-4 text-[10px] font-bold text-wine/40">{startIndex + 1}</div>
        </div>
        <div className="flex-1 relative">
          {pageR ? (
            <img src={pageR} alt={`Page ${startIndex + 2}`} className="w-full h-full object-cover" />
          ) : (
            <div className="w-full h-full bg-beige-dark flex items-center justify-center italic text-wine/20 uppercase tracking-widest font-bold">
              Son Sayfa
            </div>
          )}
          <div className="absolute bottom-4 right-4 text-[10px] font-bold text-wine/40">
            {pageR ? startIndex + 2 : ''}
          </div>
        </div>
      </motion.div>
    );
  };

  return (
    <motion.div 
      initial={{ opacity: 0 }}
      animate={{ opacity: 1 }}
      exit={{ opacity: 0 }}
      className="fixed inset-0 z-[100] bg-wine/95 backdrop-blur-xl flex flex-col items-center justify-center p-8"
    >
      <button 
        onClick={onClose}
        className="absolute top-8 right-8 p-4 text-beige hover:bg-beige/10 rounded-full transition-all"
      >
        <X size={32} />
      </button>

      <div className="relative flex items-center justify-center scale-90 lg:scale-100 perspective-1000">
        {/* Navigation Buttons */}
        <button 
          onClick={prev}
          disabled={currentPage === 0}
          className="absolute -left-20 p-4 text-beige hover:bg-beige/10 rounded-full disabled:opacity-0 transition-all z-20"
        >
          <ChevronLeft size={48} />
        </button>

        <AnimatePresence mode="wait">
          {renderContent()}
        </AnimatePresence>

        <button 
          onClick={next}
          disabled={currentPage === totalSteps - 1}
          className="absolute -right-20 p-4 text-beige hover:bg-beige/10 rounded-full disabled:opacity-0 transition-all z-20"
        >
          <ChevronRight size={48} />
        </button>
      </div>

      {/* Info Bar */}
      <div className="mt-12 text-center text-beige/60 space-y-2">
        <h2 className="font-serif text-2xl italic text-beige">{magazine.title}</h2>
        <p className="font-sans text-[10px] uppercase font-bold tracking-widest italic">Sayfa {currentPage === 0 ? '1' : `${(currentPage-1)*2 + 1} - ${(currentPage-1)*2 + 2}`} / {pages.length}</p>
      </div>

      {/* Floating Review Button */}
      <button 
        onClick={() => setShowReviews(!showReviews)}
        className="fixed bottom-8 right-8 w-16 h-16 bg-gold text-beige rounded-full shadow-2xl flex items-center justify-center hover:scale-110 active:scale-95 transition-all z-[110]"
      >
        <MessageSquare size={24} />
      </button>

      {/* Review Popup */}
      <ReviewPopup 
        isOpen={showReviews} 
        onClose={() => setShowReviews(false)} 
        magazineId={magazine.id}
      />
    </motion.div>
  );
};

export default MagazineReader;
