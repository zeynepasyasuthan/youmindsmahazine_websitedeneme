{
  "entities": {
    "Magazine": {
      "title": "Magazine",
      "description": "A monthly magazine issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "issueNumber": { "type": "number" },
        "coverUrl": { "type": "string" },
        "pages": { 
          "type": "array",
          "description": "List of URLs for each page of the magazine"
        },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "issueNumber", "coverUrl", "pages"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "An editorial article",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A user-submitted comment/review on a magazine issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "magazineId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "comment": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["magazineId", "userId", "userName", "comment", "approved", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "library": { 
          "type": "array",
          "description": "List of magazine IDs added to library"
        },
        "totalDonations": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A donation made by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "createdAt"]
    }
  },
  "firestore": {
    "magazines": {
      "schema": "Magazine",
      "description": "Published magazine issues"
    },
    "blogs": {
      "schema": "BlogPost",
      "description": "Editorial blog posts"
    },
    "reviews": {
      "schema": "Review",
      "description": "Comments on magazines"
    },
    "users": {
      "schema": "User",
      "description": "User profiles"
    },
    "donations": {
      "schema": "Donation",
      "description": "Giving records"
    }
  }
}
